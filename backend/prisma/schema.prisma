generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum InvestorProfile {
  GENERICO
  CONSERVADOR
  MODERADO
  AGRESSIVO
}

enum DecisionType {
  COMPRA_FORTE
  COMPRA
  MANTER
  VENDA
  VENDA_FORTE
}

model IndicatorConfig {
  id          String          @id @default(uuid())
  profile     InvestorProfile
  indicatorId String
  weight      Float
  idealRange  String?
  category    String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([profile, indicatorId])
  @@map("indicator_configs")
}

model ScoreThreshold {
  id        String          @id @default(uuid())
  profile   InvestorProfile
  decision  DecisionType
  minScore  Float
  emoji     String
  desc      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([profile, decision])
  @@map("score_thresholds")
}

model StockDataCache {
  id        String   @id @default(uuid())
  ticker    String
  date      String
  rawData   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ticker, date])
  @@map("stock_data_cache")
}

model Stock {
  id        String   @id @default(cuid())
  ticker    String
  sector    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ticker, sector])
  @@map("stocks")
}

model StockAnalysis {
  id           String          @id @default(uuid())
  ticker       String
  profile      InvestorProfile
  date         String
  score        Float
  decision     DecisionType
  emoji        String
  description  String
  analysisData Json
  createdAt    DateTime        @default(now())

  @@index([ticker, profile, date])
  @@map("stock_analyses")
}

model StockSector {
  id        String   @id @default(uuid())
  sectorEn  String   @unique // Setor original (brapi, Yahoo, etc) — normalizado
  sectorPt  String   // Tradução em português (pt-BR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stock_sectors")
}

model StockSectorPercentile {
  id         String   @id @default(cuid())
  ticker     String
  sector     String
  date       DateTime
  percentiles Json     // { pl: 73, pvp: 81, roe: 65, ... }
  factors    Json     // { valor: 72, qualidade: 68, momentum: 55, crescimento: 61 }
  composite  Float    // score final 0-100
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([ticker, date])
  @@map("stock_sector_percentiles")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model SectorFactorWeight {
  id        String          @id @default(uuid())
  profile   InvestorProfile
  factor    String          // "valor" | "qualidade" | "momentum" | "crescimento"
  weight    Float           // 0.0 – 1.0 (ex: 0.30 = 30%)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([profile, factor])
  @@map("sector_factor_weights")
}
